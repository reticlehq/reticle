{
  "name": "@syrin/iris-react",
  "version": "0.8.0",
  "description": "Iris React adapter — maps a DOM ref to its component stack and source file via the fiber tree.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "eslint src",
    "test:unit": "vitest run src --passWithNoTests",
    "prepack": "tsc -b && find dist -name \"*.test.*\" -delete"
  },
  "dependencies": {
    "@syrin/iris-protocol": "workspace:*",
    "@syrin/iris-browser": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "jsdom": "^26.0.0"
  },
  "license": "MIT",
  "author": "Iris contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syrin-labs/iris.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/syrin-labs/iris#readme",
  "bugs": "https://github.com/syrin-labs/iris/issues",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "keywords": [
    "mcp",
    "ai-agents",
    "react",
    "testing"
  ],
  "private": true
}
