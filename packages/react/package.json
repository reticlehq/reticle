{
  "name": "@iris/react",
  "version": "0.0.0",
  "private": true,
  "description": "Iris React adapter — maps a DOM ref to its component stack and source file via the fiber tree.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "eslint src",
    "test:unit": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@iris/protocol": "workspace:*",
    "@iris/browser": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "jsdom": "^26.0.0"
  }
}
