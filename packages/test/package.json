{
  "name": "@iris/test",
  "version": "0.2.2",
  "description": "Iris test runner: irisTest spec registry + a runner that drives Iris tools without MCP/stdio.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "eslint src",
    "test:unit": "vitest run --passWithNoTests",
    "prepack": "tsc -b && find dist -name \"*.test.*\" -delete"
  },
  "dependencies": {
    "@iris/protocol": "workspace:*",
    "@iris/server": "workspace:*"
  },
  "peerDependencies": {
    "vitest": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "license": "MIT",
  "author": "Iris contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iris-mcp/iris.git",
    "directory": "packages/test"
  },
  "homepage": "https://github.com/iris-mcp/iris#readme",
  "bugs": "https://github.com/iris-mcp/iris/issues",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "keywords": [
    "mcp",
    "ai-agents",
    "testing"
  ]
}
