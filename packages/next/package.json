{
  "name": "@reticlehq/next",
  "version": "2.1.0",
  "description": "Next.js helper for Reticle: keeps SWC, adds source-file mapping via a dev-only webpack pre-loader (data-reticle-source).",
  "license": "Apache-2.0",
  "author": "Reticle contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reticlehq/reticle.git",
    "directory": "packages/next"
  },
  "homepage": "https://github.com/reticlehq/reticle#readme",
  "keywords": [
    "reticle",
    "next",
    "nextjs",
    "source",
    "devtools"
  ],
  "main": "./index.cjs",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.cjs"
    },
    "./loader": "./loader.cjs"
  },
  "files": [
    "index.cjs",
    "loader.cjs",
    "README.md",
    "index.d.ts"
  ],
  "dependencies": {
    "@babel/core": "^7.26.0",
    "@reticlehq/babel-plugin": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=13"
  },
  "types": "./index.d.ts",
  "publishConfig": {
    "access": "public"
  }
}
