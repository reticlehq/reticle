{
  "name": "@syrin/iris-next",
  "version": "0.3.5",
  "private": false,
  "description": "Next.js helper for Iris: keeps SWC, adds source-file mapping via a dev-only webpack pre-loader (data-iris-source).",
  "license": "MIT",
  "author": "Iris contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syrin-labs/iris.git",
    "directory": "packages/next"
  },
  "homepage": "https://github.com/syrin-labs/iris#readme",
  "keywords": [
    "iris",
    "next",
    "nextjs",
    "source",
    "devtools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./index.cjs",
  "exports": {
    ".": "./index.cjs",
    "./loader": "./loader.cjs"
  },
  "files": [
    "index.cjs",
    "loader.cjs",
    "README.md"
  ],
  "dependencies": {
    "@babel/core": "^7.26.0",
    "@syrin/iris-babel-plugin": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=13"
  }
}
