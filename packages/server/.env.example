# Reticle bridge + MCP server configuration

# Port the bridge WebSocket endpoint + MCP server listen on.
RETICLE_PORT=4400

# Keep the default loopback bind unless remote browser access is intentional.
RETICLE_HOST=127.0.0.1

# Shared pairing token between the browser SDK and the bridge.
# Generate one and set the same value in the app's @reticle/browser config.
# Leave blank in pure-localhost dev; required for any non-localhost transport.
# Terminate TLS in front of the bridge and use wss:// from browsers when it is remote.
RETICLE_TOKEN=

# Comma-separated browser origins allowed in addition to localhost.
RETICLE_ALLOWED_ORIGINS=
