{
  "name": "@syrin/iris-server",
  "version": "0.4.0",
  "description": "Iris bridge + MCP server. Hosts the browser WS endpoint and exposes MCP tools to the coding agent.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "iris": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "default": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b",
    "lint": "eslint src",
    "test:unit": "vitest run --passWithNoTests",
    "prepack": "tsc -b && find dist -name \"*.test.*\" -delete"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@syrin/iris-protocol": "workspace:*",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.5.13"
  },
  "optionalDependencies": {
    "pixelmatch": "^7.2.0",
    "playwright": "^1.48.0",
    "pngjs": "^7.0.0"
  },
  "license": "MIT",
  "author": "Iris contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syrin-labs/iris.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/syrin-labs/iris#readme",
  "bugs": "https://github.com/syrin-labs/iris/issues",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "ai-agents",
    "testing",
    "cli"
  ],
  "iris": {
    "changelog": "Smart MCP proxy with auto-start daemon, auto-update, and rollback support. Agents can call iris_version_info, iris_apply_update, and iris_rollback.",
    "breakingChanges": []
  },
  "private": true
}
