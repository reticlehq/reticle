{
  "name": "@reticlehq/server",
  "version": "2.0.1",
  "description": "Reticle bridge + MCP server. Hosts the browser WS endpoint and exposes MCP tools to the coding agent.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "reticle": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "default": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b",
    "lint": "eslint src",
    "test:unit": "vitest run src --passWithNoTests",
    "prepack": "tsc -b && find dist -name \"*.test.*\" -delete"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@reticlehq/core": "workspace:*",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.5.13"
  },
  "optionalDependencies": {
    "pixelmatch": "^7.2.0",
    "playwright": "^1.48.0",
    "pngjs": "^7.0.0"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "Reticle contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reticlehq/reticle.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/reticlehq/reticle#readme",
  "bugs": "https://github.com/reticlehq/reticle/issues",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "ai-agents",
    "testing",
    "cli"
  ],
  "reticle": {
    "changelog": "Smart MCP proxy with auto-start daemon, auto-update, and rollback support. Agents can call reticle_version_info, reticle_apply_update, and reticle_rollback.",
    "breakingChanges": []
  },
  "publishConfig": {
    "access": "public"
  }
}
