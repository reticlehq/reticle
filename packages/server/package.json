{
  "name": "@iris/server",
  "version": "0.2.1",
  "description": "Iris bridge + MCP server. Hosts the browser WS endpoint and exposes MCP tools to the coding agent.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "iris": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b",
    "lint": "eslint src",
    "test:unit": "vitest run --passWithNoTests",
    "prepack": "tsc -b && find dist -name \"*.test.*\" -delete"
  },
  "dependencies": {
    "@iris/protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13"
  },
  "optionalDependencies": {
    "playwright": "^1.48.0"
  },
  "license": "MIT",
  "author": "Iris contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iris-mcp/iris.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/iris-mcp/iris#readme",
  "bugs": "https://github.com/iris-mcp/iris/issues",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "ai-agents",
    "testing",
    "cli"
  ]
}
