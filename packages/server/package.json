{
  "name": "@iris/server",
  "version": "0.0.0",
  "private": true,
  "description": "Iris bridge + MCP server. Hosts the browser WS endpoint and exposes MCP tools to the coding agent.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "iris": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b",
    "lint": "eslint src",
    "test:unit": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@iris/protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13"
  }
}
