# Research never ships — plan/ is always ignored
plan/

# Cloud control plane — the paid app carries the closed-intelligence moat and tenant/billing
# code; it must never ship in the Apache OSS repo. Developed here for velocity, extracted to a
# private repo (reticlehq/cloud) before any real secrets/tenant data. Its own git lives inside.
app/

# Marketing: keep the source (HTML/CSS/mjs) reproducible, but never commit the heavy
# render outputs or raw footage — host those on a CDN / GitHub Releases. The curated
# README media lives in assets/readme/ (a separate dir) and IS committed.
assets/clips/
assets/*.png
assets/marketing/**/*.mp4
assets/marketing/**/*.mov
assets/marketing/**/*.gif
assets/marketing/**/*.png
assets/benchmarks/*.png

# Image-generation SOURCE split: the benchmark card generators (assets/benchmarks/render.mjs +
# src/bench-*.html) and the shared design system (assets/marketing/src/_system.css) are PUBLIC —
# they generate the committed README/docs images. The GTM/marketing source and the old numbered
# card drafts stay LOCAL (design reference, never shipped to the public repo).
assets/benchmarks/src/[0-9]*.html
assets/marketing/render.mjs
assets/marketing/demo/
assets/marketing/reels/
assets/marketing/video/
assets/marketing/landscape/
assets/marketing/v0.5.0/
assets/marketing/src/*.html

# Env
.env
.env.*
!.env.example

# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
.turbo/
*.tsbuildinfo

# Test / coverage
coverage/

# Python (not used here, kept for parity with the foundation skill)
__pycache__/
.venv/
.mypy_cache/
.ruff_cache/

# Graphify artifacts
graph.json
graph.html
graphify-out/
GRAPH_REPORT.md

# Reticle local runtime artifacts
.reticle/

# Logs / OS
*.log
.DS_Store

# local registry auth token (never commit)
.npmrc

# Issuer signing keys — the license-minting private key NEVER touches git.
# (Public keys are baked into a release via env, not committed here either.)
*.pem
*.key
issuer-*.json

# Playwright MCP session dumps (written to cwd during benchmark runs)
.playwright-mcp/

# Agent git worktrees (never track — they are live checkouts)
.claude/worktrees/
leads/

# Playwright CLI benchmark disk artifacts (snapshots/console logs)
.playwright-cli/
