---
import Counter from '../components/Counter.tsx';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Reticle × Astro</title>
  </head>
  <body>
    <h1>Reticle × Astro</h1>
    <Counter client:load />
    <script>
      // Dev-only: connect Reticle on the client. Astro bundles this <script>, so the bare import resolves.
      if (import.meta.env.DEV) {
        const { reticle, install } = await import('@reticlehq/core');
        install();
        reticle.connect({ projectId: 'example-astro' });
      }
    </script>
  </body>
</html>
