---
import Counter from '../components/Counter.tsx';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Iris × Astro</title>
  </head>
  <body>
    <h1>Iris × Astro</h1>
    <Counter client:load />
    <script>
      // Dev-only: connect Iris on the client. Astro bundles this <script>, so the bare import resolves.
      if (import.meta.env.DEV) {
        const { iris, install } = await import('@syrin/iris');
        install();
        iris.connect({ projectId: 'example-astro' });
      }
    </script>
  </body>
</html>
