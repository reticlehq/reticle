# Reticle demo dashboard configuration

# WebSocket URL of the local Reticle bridge the SDK connects to in dev.
VITE_RETICLE_WS_URL=ws://localhost:4400/reticle

# Pairing token — must match RETICLE_TOKEN in the @reticlehq/server .env (blank for localhost dev).
VITE_RETICLE_TOKEN=

# Explicit opt-in for a deployed page or non-localhost bridge. Requires VITE_RETICLE_TOKEN.
VITE_RETICLE_ALLOW_NON_LOCALHOST=false
