# Live QA agent — free, OpenAI-compatible LLM provider. Copy to .env and fill in LLM_API_KEY.
# The agent is provider-portable: only these three values change.

# ── Groq (RECOMMENDED — genuinely free tier, fast, great tool calling) ──────────
# Key: https://console.groq.com/keys
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=gsk_your_free_groq_key_here

# ── Cerebras (free tier, very fast, tool calling) ───────────────────────────────
# LLM_BASE_URL=https://api.cerebras.ai/v1
# LLM_MODEL=llama-3.3-70b
# LLM_API_KEY=csk-...

# ── Google Gemini (free tier via AI Studio) ─────────────────────────────────────
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-2.5-flash
# LLM_API_KEY=AIza...

# ── Kimi / Moonshot (NOT free — needs account balance; the demo key was out of balance) ─
# LLM_BASE_URL=https://api.moonshot.ai/v1
# LLM_MODEL=kimi-k2-0711-preview
# LLM_API_KEY=sk-...
